@model List<Note>

@{
    ViewData["Title"] = "My Tasks";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>My Tasks</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Notes")" class="btn btn-primary">+ New Task</a>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var note in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@note.Title</h5>
                            <p class="card-text">@note.Content.Substring(0, Math.Min(100, note.Content.Length))@(note.Content.Length > 100 ? "..." : "")</p>
                            <small class="text-muted">Created: @note.CreatedAt.ToString("MMM dd, yyyy")</small>
                            <div class="mt-3">
                                <a href="@Url.Action("Edit", "Notes", new { id = note.Id })" class="btn btn-sm btn-warning">Edit</a>
                                <a href="@Url.Action("Delete", "Notes", new { id = note.Id })" class="btn btn-sm btn-danger">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <p>No tasks yet. <a href="@Url.Action("Create", "Notes")">Create your first task</a></p>
        </div>
    }
</div>
